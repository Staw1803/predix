rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is logged in
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if the user is an admin or creator
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }

    // --- USERS ---
    match /users/{userId} {
      allow read: if isAuthenticated();
      
      // Allow creation of profile document upon signup
      allow create: if isAuthenticated() && request.auth.uid == userId;
      
      // Allow updates to profile but PREVENT users from elevating their privileges (isAdmin, role)
      allow update: if isAuthenticated() && request.auth.uid == userId && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'role']);
    }

    // --- POSTS ---
    match /posts/{postId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // --- COMMENTS ---
    match /comments/{commentId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.authorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.authorId == request.auth.uid;
    }

    // --- FOLLOWS ---
    match /follows/{followId} {
      allow read: if isAuthenticated();
      allow create, delete: if isAuthenticated() && (
        request.auth.uid == request.resource.data.followerId || 
        request.auth.uid == resource.data.followerId
      );
    }

    // --- PREDICTIONS & BETS ---
    match /predictions/{predictionId} {
      allow read: if isAuthenticated();
      
      // Only admins can create predictions
      allow create: if isAdmin();
      
      // Only admins can resolve or cancel predictions.
      // Normal users can only update the pools (poolYes, poolNo) when placing a bet.
      allow update: if isAdmin() || (
        isAuthenticated() && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['question', 'source', 'category', 'status', 'outcome', 'resolvedAt'])
      );
      
      allow delete: if isAdmin();

      // Bets subcollection
      match /bets/{betId} {
        allow read: if isAuthenticated();
        
        // A user can place a bet for themselves only if the prediction is still open
        allow create: if isAuthenticated() && 
          request.resource.data.userId == request.auth.uid &&
          get(/databases/$(database)/documents/predictions/$(predictionId)).data.status == 'open';
          
        // Bets cannot be altered or deleted once placed
        allow update, delete: if false;
      }
    }
  }
}
